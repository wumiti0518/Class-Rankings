rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: state
    // Document ID: current
    // Fields:
    //   - groups: list (required) - Array of Group objects
    //   - updatedAt: number (required) - Timestamp of last update
    //
    // Collection: logs
    // Document ID: auto-generated
    // Fields:
    //   - id: string (required)
    //   - timestamp: number (required)
    //   - type: string (required, enum: score, move, reset, leader, save)
    //   - message: string (required)
    //   - data: list (optional) - Snapshot of groups
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "wumitialimujiang.xxx@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    
    function isValidMember(member) {
      return member is map &&
             member.name is string && member.name.size() > 0 && member.name.size() < 50 &&
             member.score is number &&
             member.bonus is number;
    }

    function isValidGroup(group) {
      return group is map &&
             group.id is number &&
             group.leader is string && group.leader.size() < 50 &&
             group.members is list &&
             group.members.size() <= 20; // Max 20 members per group
    }

    function isValidAppState(data) {
      return hasRequiredFields(['groups', 'updatedAt']) &&
             hasOnlyAllowedFields(['groups', 'updatedAt']) &&
             data.groups is list &&
             data.groups.size() <= 30 && // Max 30 groups
             data.updatedAt is number;
    }

    function isValidLogEntry(data) {
      return hasRequiredFields(['id', 'timestamp', 'type', 'message']) &&
             data.id is string &&
             data.timestamp is number &&
             data.type in ['score', 'move', 'reset', 'leader', 'save'] &&
             data.message is string && data.message.size() < 500;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /state/current {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidAppState(request.resource.data);
    }

    match /logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidLogEntry(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
